# Path to local MP4 video file (H264+audio)
VIDEO_FILE=main.mp4

# URL to download MP4 from if VIDEO_FILE doesn't exist locally
VIDEO_URL=https://github.com/gostrix/StrixCamFake/raw/main/main.mp4

# HomeKit camera name (visible in Apple Home app)
CAMERA_NAME=StrixCam

# HomeKit pairing PIN (8 digits, no dashes)
PIN=19550224

# HAP server port (TCP -- pair-setup, pair-verify, accessories)
HAP_PORT=51826

# SRTP server port (UDP -- video/audio streaming)
SRTP_PORT=8443

# Camera metadata
CAMERA_MODEL=SAHK-1000
CAMERA_SERIAL=SAHK-001
CAMERA_FIRMWARE=1.0.0

# Snapshot refresh interval
SNAPSHOT_INTERVAL=5s
